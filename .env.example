# ──────────────────────────────────────────────────────────────────────────────
# Real Estate Multi-Agent System — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── Sarvam AI (LLM) ──────────────────────────────────────────────────────────
SARVAM_API_KEY=sk_gshq4joz_RcZD1Na4zdF1E7DaIggzhvPS
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_MODEL=sarvam-30b

# ── Pinecone (Vector DB) ─────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_25WGe1_QiLnDdSG7oJ4vBoWEUSziK1nQRM2vZy1wCXgYBHJBMQGagVYRmULRTzqjinoVZT
PINECONE_INDEX_NAME=realestate-insights
PINECONE_ENVIRONMENT=us-east-1           # AWS region for your Pinecone serverless index

# ── Embedding Model ──────────────────────────────────────────────────────────
# Uses sentence-transformers (free, runs locally — no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Persistence ──────────────────────────────────────────────────────────────
DB_PATH=data/db/realestate.db

# ── Agent URLs ───────────────────────────────────────────────────────────────
# Change these if running on different hosts/ports (e.g. Docker)
CUSTOMER_AGENT_URL=http://localhost:8001
DEAL_AGENT_URL=http://localhost:8002
MARKETING_AGENT_URL=http://localhost:8003
CONCIERGE_AGENT_URL=http://localhost:8000
